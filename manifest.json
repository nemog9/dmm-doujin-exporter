{
  "manifest_version": 3,
  "name": "DMM Doujin Exporter",
  "version": "1.3",
  "description": "DMMマイライブラリの同人作品情報（ボイス・コミック・CG）をCSVでエクスポート",
  "permissions": ["scripting", "activeTab", "storage", "tabs", "downloads"],
  "host_permissions": ["https://www.dmm.co.jp/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
